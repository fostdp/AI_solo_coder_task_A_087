# ===== 金箔锻制系统 - Docker 环境变量 =====
# 复制为 .env 后按需修改

# ---- 网络端口 ----
BACKEND_PORT=8000
INFLUXDB_PORT=8086
REDIS_PORT=6379

# ---- FastAPI 后端 ----
BACKEND_WORKERS=4

# ---- InfluxDB ----
INFLUXDB_USER=admin
INFLUXDB_PASS=gold-foil-admin-pass
INFLUXDB_ORG=craftsman-research
INFLUXDB_BUCKET=gold-foil-data
INFLUXDB_TOKEN=gold-foil-simulation-token

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- 模拟器 (可选, docker compose --profile simulator up) ----
# 可选预设: nanjing_wujin | kaipi | yanhou | jingzheng | ai_optimized
SIM_PRESET=nanjing_wujin
SIM_COMMAND=--preset nanjing_wujin
SIM_FOIL_ID=NF-DOCKER-001
SIM_CRAFTSMAN_ID=master_wu
SIM_REPORT_INTERVAL=60
